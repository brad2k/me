---
const { pathname } = Astro.url;

interface Props {
  to?: string;
  label: string;
  [key: string]: any;
}

const { label, to, ...rest } = Astro.props;
---

<a href={to} class:list={[{ active: to && pathname.includes(to) }]} {...rest}
  >{label}</a
>

<style>
  .active {
    color: var(--color-link-active);
  }
</style>
