---
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Component extends HTMLTag> = Polymorphic<{
  as: Component;
  children: any;
}>;

const { as: Component = "div", class: className, ...rest } = Astro.props;
---

<Component class:list={["card", className]} {...rest}>
  <slot />
</Component>

<style>
  .card {
    background-color: var(--card-bg, var(--color-surface));
    padding: var(--card-padding, var(--space-m));
    border-radius: var(--card-border-radius, var(--radius-tight));
  }

  :global(.card-title) {
    font-size: var(--card-title-font-size, var(--font-size-h3));
  }
</style>
