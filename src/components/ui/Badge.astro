---
interface Props {
  as?: HTMLElement;
  class?: string;
  [key: string]: any;
}

const { as = "span", class: className, ...rest } = Astro.props;

const Element = as;
---

<Element class:list={["badge", className]} {...rest}>
  <slot />
</Element>

<style>
  .badge {
    background-color: var(--badge-bg, var(--color-surface));
    padding: var(--space-xs);
    border-radius: var(--radius-s);
    white-space: nowrap;
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-extra-small);
    line-height: var(--leading-flat);
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: fit-content;
  }
</style>
