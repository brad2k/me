---
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Component extends HTMLTag> = Polymorphic<{
  as: Component;
  children: any;
}>;

const { as: Component = "div", class: className, ...rest } = Astro.props;
---

<Component class:list={["badge", className]} {...rest}>
  <slot />
</Component>

<style>
  .badge {
    background-color: var(--badge-bg, var(--color-surface));
    padding: var(--space-xs);
    border-radius: var(--radius-tight);
    white-space: nowrap;
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-extra-small);
    line-height: var(--leading-flat);
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: fit-content;
  }
</style>
