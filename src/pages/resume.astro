---
import { ChevronDown, Mail, Printer } from "@lucide/astro";
import { Font, Image } from "astro:assets";
import BradAzevedoScreen from "../assets/bradazevedo.com.png";
import GitHub from "../assets/github-logo.svg";
import JamesButtonScreen from "../assets/jamesbuttonoboe.com.png";
import LinkedIn from "../assets/linkedin-logo.svg";
import BeelineScreen from "../assets/thebeeline.bike.png";
import Page from "../components/Page.astro";
import Badge from "../components/ui/Badge.astro";
import resume from "../data/resume.json";

const year = new Date().getFullYear();
const timespan = year - 2006;
---

<Page
  pageTitle="Resumé | Brad Azevedo"
  pageDescription={`Resumé for Brad Azevedo, front-end engineer and UI architect for more than ${timespan} years.`}
  class="resume"
>
  <Font cssVariable="--font-Fira" slot="head" />

  <header class="flow">
    <h1><span class="visually-hidden">Resum&eacute; of </span> Brad Azevedo</h1>

    <section>
      <h2 class="visually-hidden">Connect with me</h2>
      <ul class="contacts">
        <li>
          <Mail />
          <a
            href="mailto:brad2k@gmail.com?subject=Howdy!"
            rel="external noopener"
          >
            <span class="contact--label">Email</span>
            <span class="contact--content">brad2k@gmail.com</span>
          </a>
        </li>
        <li>
          <LinkedIn />
          <a
            href="https://www.linkedin.com/in/bradazevedo"
            rel="external noopener"
          >
            <span class="contact--label">LinkedIn</span>
            <span class="contact--content">/in/bradazevedo</span>
          </a>
        </li>
        <li>
          <GitHub />
          <a href="https://github.com/brad2k" rel="external noopener">
            <span class="contact--label">GitHub</span>
            <span class="contact--content">/brad2k</span>
          </a>
        </li>
        <li class="contact--print">
          <Printer />
          <button id="print">Print/Save as a PDF</button>
        </li>
      </ul>
    </section>

    <p class="summary">
      Front-end engineer of {timespan} years on a journey spanning from IE6 to AI-assisted
      development. Specializing in the front of the front-end. Think: responsive UI
      architecture &amp; development, design systems, and generally <em
        >snazzy</em
      > UX. Also: I’m an instrument-rated private pilot.
    </p>
  </header>

  <section class="resume-section">
    <h2><span class="visually-hidden">Experience </span>Timeline</h2>

    {
      resume.timeline.map((job) => {
        return (
          <article class="job flow">
            <dl class="highlight">
              <div class="dt-block">
                <dt>{job.company}</dt>
                <dd>
                  <time datetime={job.dates.replace("—", "/")}>
                    {job.dates}
                  </time>
                </dd>
                {job.title && <dd>{job.title}</dd>}
                {job.city && <dd>{job.city}</dd>}
              </div>
            </dl>

            <ul class="bullets">
              {job.bullets.map((thing) => (
                <li>{thing}</li>
              ))}
            </ul>

            <details class="editorial">
              <summary>
                <ChevronDown />
                <span>Behind the bullet points</span>
              </summary>

              <Fragment set:html={job.editorial} />
            </details>
          </article>
        );
      })
    }
  </section>

  <section class="resume-section">
    <h2>Education</h2>

    <dl class="highlight">
      {
        resume.education.map((knowledge) => {
          return (
            <div class="dt-block">
              <dt>{knowledge.highlight}</dt>
              <dd>
                <time datetime={knowledge.year.replace("—", "/")}>
                  {knowledge.year}
                </time>
              </dd>
              {knowledge.certification && <dd>{knowledge.certification}</dd>}
              {knowledge.city && <dd>{knowledge.city}</dd>}
            </div>
          );
        })
      }
    </dl>
  </section>

  <section class="resume-section skills">
    <h2>Skills</h2>

    <dl class="skill-list">
      <dt>Core</dt>
      {resume.skills.core.map((skill) => <Badge as="dd">{skill}</Badge>)}
    </dl>

    <dl class="skill-list">
      <dt>Growing</dt>
      {resume.skills.growing.map((skill) => <Badge as="dd">{skill}</Badge>)}
    </dl>

    <dl class="skill-list">
      <dt>Also</dt>
      {resume.skills.also.map((skill) => <Badge as="dd">{skill}</Badge>)}
    </dl>
  </section>

  <section class="resume-section">
    <h2>Projects</h2>

    <p class="subtle">These are some projects I’ve worked on recently.</p>

    <ul class="grid project-grid">
      <li>
        <figure>
          <a href="https://thebeeline.bike/" rel="external noopener">
            <Image
              src={BeelineScreen}
              alt="Screenshot of the homepage of thebeeline.bike"
              layout="constrained"
            />
          </a>
          <figcaption>
            <p>
              The Beeline: a showcase of road biking routes in San Francisco.
            </p>
            <div><Badge>NextJS</Badge> <Badge>React</Badge></div>
          </figcaption>
        </figure>
      </li>
      <li>
        <figure>
          <a href="https://jamesbuttonoboe.com/" rel="external noopener">
            <Image
              src={JamesButtonScreen}
              alt="Screenshot of the homepage of jamesbuttonoboe.com"
              layout="constrained"
            />
          </a>
          <figcaption>
            <p>
              James Button Oboe: a personal website for classical oboe musician
              James Button.
            </p>
            <div><Badge>Astro</Badge> <Badge>Sanity CMS</Badge></div>
          </figcaption>
        </figure>
      </li>
      <li>
        <figure>
          <a href="/">
            <Image
              src={BradAzevedoScreen}
              alt="Screenshot of the homepage of this website, bradazevedo.com"
              layout="constrained"
            />
          </a>
          <figcaption>
            <p>Brad Azevedo: a brand-new personal website for myself.</p>
            <div><Badge>Astro</Badge></div>
          </figcaption>
        </figure>
      </li>
    </ul>
  </section>

  <section class="resume-section">
    <h2>Outside of work</h2>

    <p class="subtle">
      Summaries of academic and professional achievements are one piece of the
      picture, but our identities and professional value as humans are informed
      by the experiences and knowledge from our personal life. Head on over to
      the <a href="/about/">About Me</a> page to learn more about what makes me tick.
    </p>
  </section>
</Page>

<style>
  .resume {
    font-family: var(--font-Fira);
  }

  .summary {
    --flow-space: var(--space-l);
    border-inline-start: 5px solid var(--color-accent);
    padding-inline-start: var(--gutter);
  }

  .contacts {
    display: flex;
    flex-wrap: wrap;
    column-gap: var(--space-l);
    row-gap: var(--space-s);
    align-items: center;
    font-size: var(--font-size-subtle);
    line-height: var(--leading-flat);

    li {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      white-space: nowrap;
    }

    svg {
      height: 1em;
      width: 1em;
    }

    a {
      text-decoration: none;
    }
  }

  .contact--content {
    display: none;
  }

  #print {
    &:hover {
      color: var(--color-link-active);
    }
  }

  .dt-block {
    display: grid;
    gap: 0.25em; /* based on the root font size so it aligns with the "summary" paragraph */
    grid-template-columns: 1fr auto;
  }

  .highlight {
    display: grid;
    gap: var(--space-m);
    text-wrap: balance;
    line-height: var(--leading-fine);

    dt {
      font-weight: 700;
      font-size: var(--font-size-subtle);
    }

    dd {
      font-size: var(--font-size-small);

      &:nth-child(even) {
        place-self: end;
      }
    }
  }

  .job {
    --flow-space: var(--space-s);
  }

  .bullets {
    padding-inline-start: var(--space-s);
    list-style-type: disc;
    font-size: var(--font-size-small);
  }

  .resume-section {
    --flow-space: var(--space-xl);

    display: grid;
    gap: var(--space-l);

    h2 {
      padding-block-end: var(--space-xs);
      border-bottom: 1px solid var(--color-surface);
    }
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);

    dt {
      flex-basis: 100%;
      font-family: var(--font-Fira);
      font-size: var(--font-size-base);
    }

    dd {
      font-size: var(--font-size-small);
    }
  }

  .editorial {
    font-size: var(--font-size-small);

    ::marker {
      content: "";
    }

    &::details-content {
      overflow: hidden;
      transition:
        block-size var(--transition-base),
        content-visibility var(--transition-base) allow-discrete;
      block-size: 0;
    }

    .lucide {
      height: 1.5em;
      width: 1.5em;
      transition: transform var(--transition-base);
    }

    summary {
      list-style-position: outside;
      line-height: var(--leading-flat);
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      color: var(--color-accent);
      cursor: pointer;

      &:hover {
        font-weight: 500;
      }
    }

    p {
      padding-inline-start: var(--space-m);
      margin-block-start: var(--space-s);
    }

    &[open] {
      &::details-content {
        block-size: auto;
      }

      .lucide {
        transform: rotate(180deg);
      }
    }
  }

  .project-grid {
    --flow-space: var(--space-s);
    font-size: var(--font-size-small);

    img {
      border-radius: var(--radius-s);
      aspect-ratio: 4 / 3;
    }

    a {
      text-decoration: none;
    }

    li {
      display: grid;
      grid-template-rows: subgrid;
      row-gap: var(--space-xs);
      grid-row: span 2; /* Two rows: one for the img, one for the caption */
    }

    figure {
      display: grid;
      grid-template-rows: subgrid;
      grid-row: span 2;
    }

    figcaption {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: var(--space-xs);
    }
  }

  @media print {
    :global(.primary-header, .footer) {
      display: none;
    }

    .editorial {
      &::details-content {
        block-size: auto;
        content-visibility: visible;
      }

      summary {
        font-weight: 500;
      }
    }

    .contact--content {
      display: block;
    }

    .contact--label {
      display: none;
    }

    .contact--print {
      display: none !important;
    }
  }
</style>

<script>
  const printTrigger = document.getElementById("print");
  printTrigger?.addEventListener("click", () => window.print());
</script>
